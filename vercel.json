{
  "version": 2,
  "name": "bot-whatsapp-automotora",
  "builds": [
    {
      "src": "main_production.py",
      "use": "@vercel/python"
    },
    {
      "src": "chat_simple.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "chat_simple.py"
    },
    {
      "src": "/chat",
      "dest": "chat_simple.py"
    },
    {
      "src": "/test",
      "dest": "main_production.py"
    },
    {
      "src": "/dashboard_admin",
      "dest": "main_production.py"
    },
    {
      "src": "/atribuir_venta",
      "dest": "main_production.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
