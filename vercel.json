{
  "version": 2,
  "name": "bot-whatsapp-automotora",
  "builds": [
    {
      "src": "main_simple.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main_simple.py"
    }
  ],
  "functions": {
    "main_simple.py": {
      "maxDuration": 30
    }
  },
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
